@inherits LayoutComponentBase
@using Portiforce.SAA.Web.Client.Shared

<div class="page">
    <div class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">
                    <span class="brand-icon">🛡️</span>
                    <div class="brand-text">
                        <div class="brand-title">PortiForce</div>
                        <div class="brand-subtitle">Simple Asset Assistant</div>
                    </div>
                </a>
            </div>
        </div>
        <NavMenu />
        <div class="sidebar-footer">
            <LoginDisplay />
        </div>
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-left">
                <label for="sidebarToggle" class="navbar-toggler">
                    <span class="navbar-toggler-icon"></span>
                </label>
            </div>
            <div class="top-row-right">
                <AuthorizeView>
                    <Authorized>
                        <a href="tenant/user/portfolio" class="btn btn-link">
                            <span class="bi bi-house-door"></span>
                        </a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            <TenantProvider>
                @Body
            </TenantProvider>
        </article>
    </main>
</div>

<ReconnectModal />