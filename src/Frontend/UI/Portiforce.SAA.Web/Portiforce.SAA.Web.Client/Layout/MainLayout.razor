@inherits LayoutComponentBase
@using Portiforce.SAA.Contracts
@using Portiforce.SAA.Contracts.Models.Client
@using Portiforce.SAA.Web.Client.Shared

<div class="app-shell">
    <aside class="sidebar @(isSidebarCollapsed ? "collapsed" : "")">
        <div class="brand">
            <div class="brand-title">PortiForce</div>
            <div class="brand-subtitle">Simple Asset Assistant</div>
        </div>

        <NavMenu />

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <div class="user-box">
                        <div class="user-name">@DisplayName</div>
                        <div class="user-sub">Signed in</div>

                        <a class="btn btn-outline-light btn-sm w-100 mt-2" href="@AuthRoutes.Logout">
                            Log out
                        </a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="user-box">
                        <div class="user-name">Guest</div>
                        <div class="user-sub">Not signed in</div>

                        <a class="btn btn-primary btn-sm w-100 mt-2" href="@AuthRoutes.Login">
                            Log in
                        </a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <button class="icon-btn" type="button" @onclick="ToggleSidebar" aria-label="Toggle menu">
                ☰
            </button>

            <div class="topbar-title">
                @PageTitle
            </div>

            <div class="topbar-right">
                <AuthorizeView>
                    <Authorized>
                        <span class="muted">Hi, @ShortName</span>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <section class="content">
            <TenantProvider>
                @Body
            </TenantProvider>
        </section>
    </main>
</div>

<ReconnectModal />

@code {
    private bool isSidebarCollapsed;

    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
    [CascadingParameter] private TenantInfo? Tenant { get; set; }

    private string DisplayName { get; set; } = "User";
    private string ShortName { get; set; } = "User";
    private string PageTitle => "Dashboard";

    protected override async Task OnParametersSetAsync()
    {
        if (AuthenticationStateTask is null)
        {
            return;
        }

        var auth = await AuthenticationStateTask;
        var user = auth.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            // You can adjust claim selection depending on your auth setup.
            var name =
                user.Identity.Name
                ?? user.FindFirst("name")?.Value
                ?? user.FindFirst("preferred_username")?.Value
                ?? user.FindFirst("email")?.Value
                ?? "User";

            DisplayName = name;
            ShortName = name.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? name;
        }
        else
        {
            DisplayName = "Guest";
            ShortName = "Guest";
        }
    }

    private void ToggleSidebar() => isSidebarCollapsed = !isSidebarCollapsed;
}
