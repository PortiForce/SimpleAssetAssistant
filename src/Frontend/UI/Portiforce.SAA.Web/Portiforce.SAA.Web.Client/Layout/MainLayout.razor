@inherits LayoutComponentBase
@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Web.Client.Shared
@inject IStringLocalizer<MainLayout> L

<div class="page">
    <div class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">
                    <div class="brand-text">
                        <div class="brand-title">PortiForce</div>
                        <div class="brand-subtitle">@L["BrandSubtitle"]</div>
                    </div>
                </a>
            </div>
        </div>
        <NavMenu />
        <div class="sidebar-footer">
            <LoginDisplay />
        </div>
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-left">
                <label for="sidebarToggle" class="navbar-toggler">
                    <span class="navbar-toggler-icon"></span>
                </label>
            </div>
            <div class="top-row-right">
                <AuthorizeView>
                    <Authorized>
                        <a href="tenant/user/portfolio" class="btn btn-link" title="@L["HomeLinkTitle"]" aria-label="@L["HomeLinkTitle"]">
                            <span class="bi bi-house-door"></span>
                        </a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            <TenantProvider>
                @Body
            </TenantProvider>
        </article>

        <footer class="site-footer px-4">
            <span>@string.Format(L["Copyright"], DateTimeOffset.UtcNow.Year)</span>
            <a href="https://github.com/PortiForce/SimpleAssetAssistant" target="_blank" rel="noopener noreferrer">
                @L["GitHubLink"]
            </a>
            <NavLink href="/about">@L["AboutLink"]</NavLink>
            <NavLink href="/terms">@L["TermsLink"]</NavLink>
            <NavLink href="/disclaimer">@L["DisclaimerLink"]</NavLink>
        </footer>
    </main>
</div>

<ReconnectModal />
