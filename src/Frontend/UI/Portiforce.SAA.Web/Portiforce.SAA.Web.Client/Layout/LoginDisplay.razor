@implements IDisposable
@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Contracts.Contexts

@inject ITenantUrlContext TenantUrlContext
@inject NavigationManager NavigationManager
@inject IStringLocalizer<LoginDisplay> L

<AuthorizeView>
    <Authorized>
        <div class="user-info">
            <span class="user-greeting">@L["InfoGreetingHelloUser", GetUserName(context.User)]</span>
            <form action="@AuthRoutes.Logout" method="post">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                <button type="submit" class="btn-logout">
                    <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span>@L["ActionLogout"]
                </button>
            </form>
        </div>
    </Authorized>
    <NotAuthorized>
        @if (IsTenantResolved())
        {
            <a href="@AuthRoutes.Login" class="btn-login">
                <span class="bi bi-person-circle"></span>
                @L["ActionLogin"]
            </a>
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private bool IsTenantResolved()
    {
        var parts = TenantUrlContext.GetDomainParts();
        return parts.Length > 2;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private string GetUserName(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.Identity?.Name 
            ?? user.FindFirst("firstName")?.Value
            ?? user.FindFirst("name")?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? user.FindFirst("email")?.Value?.Split('@')[0]
            ?? "User";
    }
}
