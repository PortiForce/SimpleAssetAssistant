@page "/auth/login"
@inject NavigationManager Navigation

<PageTitle>Sign in · PortiForce</PageTitle>

@if (!IsTenantResolved())
{
    <div class="landing">
        <div class="landing-card">
            <div class="brand">
                <div class="brand-mark">🛡️</div>
            </div>

            <h1 class="title">Welcome to PortiForce</h1>
            <p class="subtitle">
                Sign-in is available only when a tenant subdomain is resolved.
            </p>

            <div class="info">
                <div class="info-title">How to sign in</div>
                <div class="info-text">
                    Open your tenant URL (for example: <code>yourtenant.yourdomain.com</code>) and then return to this page.
                </div>
            </div>

            <div class="actions">
                <a class="btn-link" href="/">Back to home</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="page">
        <div class="panel container card">
            <div class="brand">
                <div class="brand-mark">🛡️</div>
            </div>

            <h1 class="title">Sign in</h1>
            <p class="subtitle">to continue to PortiForce</p>

            <div class="button-container">
                <a class="btn btn-google" href="@GoogleLoginHref">
                    <svg class="btn-icon-svg" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        <path fill="none" d="M1 1h22v22H1z" />
                    </svg>
                    Continue with Google
                </a>

                <button class="btn btn-disabled" type="button" disabled aria-disabled="true" title="Coming soon">
                    <span class="btn-icon" aria-hidden="true"></span>
                    Continue with Apple
                </button>

                <button class="btn btn-disabled" type="button" disabled aria-disabled="true" title="Coming soon">
                    <span class="btn-icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2L2 11.5l6 2.5 11.5-10-8 10.5v5.5l3.5-3.5 4.5 4.5 2-19z" /></svg>
                    </span>
                    Continue with Telegram
                </button>
            </div>

            <div class="fineprint">
                By continuing, you confirm you’re signing in to the current tenant site.
            </div>
        </div>
    </div>
}

@code {
    private string GoogleLoginHref => string.IsNullOrWhiteSpace(_inviteToken)
        ? "/auth/login/google"
        : $"/auth/login/google?inviteToken={Uri.EscapeDataString(_inviteToken)}";

    private readonly string? _inviteToken;

    public Login()
    {
		
    }

    private bool IsTenantResolved()
    {
        var uri = new Uri(Navigation.Uri);
        var host = uri.Host;

        // Mirrors current Home.razor behavior: tenant resolved when host has a subdomain.
        var parts = host.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length > 2;
    }

    private static string? TryGetQueryParam(Uri uri, string key)
    {
        var query = uri.Query;
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 0)
            {
                continue;
            }

            if (!string.Equals(Uri.UnescapeDataString(kv[0]), key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            return kv.Length == 2 ? Uri.UnescapeDataString(kv[1]) : string.Empty;
        }

        return null;
    }
}