@page "/auth/login"
@inject NavigationManager Navigation

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Login> L

<PageTitle>@L["PageTitle"]</PageTitle>

@if (!IsTenantResolved())
{
    <div class="pf-auth-shell">
        <div class="pf-auth-card pf-auth-card--info">
            <div class="pf-auth-brand">
                <div class="pf-auth-brand-mark">🛡️</div>
                <div class="pf-auth-brand-text">
                    <div class="pf-auth-product">PortiForce</div>
                    <div class="pf-auth-product-subtext">@L["BrandProductSubtextTenantSecureAccess"]</div>
                </div>
            </div>

            <h1 class="pf-auth-title">@L["TitleTenantNotResolved"]</h1>
            <p class="pf-auth-subtitle">
                @L["SubtitleTenantNotResolved"]
            </p>

            <div class="pf-auth-info-box">
                <div class="pf-auth-info-title">@L["InfoTitleHowToSignIn"]</div>
                <div class="pf-auth-info-text">
                    @L["InfoTextTenantResolutionHint", "yourtenant.yourdomain.com"]
                </div>
            </div>

            <div class="pf-auth-footer-actions">
                <a class="pf-auth-link" href="/">@L["ActionBackToHome"]</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="pf-auth-shell">
        <div class="pf-auth-card">
            <div class="pf-auth-brand">
                <div class="pf-auth-brand-mark">🛡️</div>
                <div class="pf-auth-brand-text">
                    <div class="pf-auth-product">PortiForce</div>
                    <div class="pf-auth-product-subtext">@L["BrandProductSubtextTenantAwareSignIn"]</div>
                </div>
            </div>

            <div class="pf-auth-header">
                <h1 class="pf-auth-title">@L["TitleSignIn"]</h1>
                <p class="pf-auth-subtitle">@L["SubtitleSignInToWorkspace"]</p>
            </div>

            <div class="pf-auth-providers">
                <a class="pf-provider-btn" href="@GoogleLoginHref">
                    <span class="pf-provider-btn__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                    </span>
                    <span class="pf-provider-btn__label">@L["ActionContinueWithGoogle"]</span>
                </a>

                <button class="pf-provider-btn pf-provider-btn--disabled" type="button" disabled aria-disabled="true" title="Coming soon">
                    <span class="pf-provider-btn__icon pf-provider-btn__icon--mono" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                            <path d="M16.365 1.43c0 1.14-.41 2.02-1.02 2.76-.67.79-1.76 1.4-2.83 1.31-.14-1.06.39-2.07.99-2.73.66-.74 1.81-1.29 2.86-1.34zM19.47 17.09c-.49 1.11-.73 1.61-1.36 2.58-.87 1.35-2.09 3.04-3.6 3.05-1.34.01-1.69-.88-3.51-.87-1.82.01-2.21.89-3.55.88-1.51-.01-2.66-1.53-3.54-2.88-2.46-3.79-2.72-8.24-1.2-10.58 1.08-1.66 2.78-2.63 4.38-2.63 1.63 0 2.65.89 4 .89 1.31 0 2.11-.89 3.98-.89 1.43 0 2.95.78 4.02 2.12-3.54 1.94-2.97 7.02.38 8.33z" />
                        </svg>
                    </span>
                    <span class="pf-provider-btn__label">@L["ActionContinueWithApple"]</span>
                    <span class="pf-provider-btn__badge">@L["BadgeComingSoon"]</span>
                </button>

                <button class="pf-provider-btn pf-provider-btn--disabled" type="button" disabled aria-disabled="true" title="Coming soon">
                    <span class="pf-provider-btn__icon pf-provider-btn__icon--telegram" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21.5 2 2 11.5l6 2.5 11.5-10-8 10.5v5.5l3.5-3.5 4.5 4.5 2-19z" />
                        </svg>
                    </span>
                    <span class="pf-provider-btn__label">@L["ActionContinueWithTelegram"]</span>
                    <span class="pf-provider-btn__badge">@L["BadgeComingSoon"]</span>
                </button>
            </div>

            <div class="pf-auth-divider">
                <span>@L["DividerOr"]</span>
            </div>

            <div class="pf-auth-note">
                @L["InfoSignInToCurrentTenantSite"]
            </div>
        </div>
    </div>
}

@code {
    private string? _inviteToken;

    private string GoogleLoginHref => string.IsNullOrWhiteSpace(_inviteToken)
        ? "/auth/login/google"
        : $"/auth/login/google?inviteToken={Uri.EscapeDataString(_inviteToken)}";

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        _inviteToken = TryGetQueryParam(uri, "inviteToken");
    }

    private bool IsTenantResolved()
    {
        var uri = new Uri(Navigation.Uri);
        var host = uri.Host;

        var parts = host.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length > 2;
    }

    private static string? TryGetQueryParam(Uri uri, string key)
    {
        var query = uri.Query;
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 0)
            {
                continue;
            }

            if (!string.Equals(Uri.UnescapeDataString(kv[0]), key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            return kv.Length == 2 ? Uri.UnescapeDataString(kv[1]) : string.Empty;
        }

        return null;
    }
}