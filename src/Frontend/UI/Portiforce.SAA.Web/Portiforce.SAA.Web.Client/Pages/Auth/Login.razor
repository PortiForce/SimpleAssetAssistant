@page "/auth/login"
@inject NavigationManager Navigation

<PageTitle>Sign in · PortiForce</PageTitle>

@if (!IsTenantResolved())
{
	<div class="landing">
		<div class="landing-card">
			<div class="brand">
				<div class="brand-mark">🛡️</div>
				<div>
					<div class="brand-name">PortiForce</div>
					<div class="brand-sub">Simple Asset Assistant</div>
				</div>
			</div>

			<h1 class="h1">Welcome</h1>
			<p class="lead">
				This is the public landing experience. Sign-in is available only when a tenant subdomain is resolved.
			</p>

			<div class="info">
				<div class="info-title">How to sign in</div>
				<div class="info-text">
					Open your tenant URL (for example: <code>yourtenant.yourdomain.com</code>) and then return to this page.
				</div>
			</div>

			<a class="btn-link" href="/">Back to home</a>
		</div>
	</div>
}
else
{
	<div class="page">
		<div class="brand">
			<div class="brand-mark">🛡️</div>
			<div>
				<div class="brand-name">PortiForce</div>
				<div class="brand-sub">Simple Asset Assistant</div>
			</div>
		</div>

		<h1 class="title">Sign in to PortiForce</h1>

		<div class="panel">
			<a class="btn btn-primary" href="@GoogleLoginHref">
				<span class="btn-icon" aria-hidden="true">G</span>
				Continue with Google
			</a>

			<button class="btn btn-disabled" type="button" disabled aria-disabled="true" title="Coming soon">
				<span class="btn-icon" aria-hidden="true"></span>
				Continue with Apple
				<span class="pill">Disabled</span>
			</button>

			<button class="btn btn-disabled" type="button" disabled aria-disabled="true" title="Coming soon">
				<span class="btn-icon" aria-hidden="true">TG</span>
				Continue with Telegram
				<span class="pill">Disabled</span>
			</button>

			<div class="fineprint">
				By continuing, you confirm you’re signing in to the current tenant site.
			</div>
		</div>
	</div>
}

@code {
	private string GoogleLoginHref => string.IsNullOrWhiteSpace(_inviteToken)
		? "/auth/login/google"
		: $"/auth/login/google?inviteToken={Uri.EscapeDataString(_inviteToken)}";

	private readonly string? _inviteToken;

	public Login()
	{
		
	}

	private bool IsTenantResolved()
	{
		var uri = new Uri(Navigation.Uri);
		var host = uri.Host;

		// Mirrors current Home.razor behavior: tenant resolved when host has a subdomain.
		var parts = host.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
		return parts.Length > 2;
	}

	private static string? TryGetQueryParam(Uri uri, string key)
	{
		var query = uri.Query;
		if (string.IsNullOrWhiteSpace(query))
		{
			return null;
		}

		foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
		{
			var kv = part.Split('=', 2);
			if (kv.Length == 0)
			{
				continue;
			}

			if (!string.Equals(Uri.UnescapeDataString(kv[0]), key, StringComparison.OrdinalIgnoreCase))
			{
				continue;
			}

			return kv.Length == 2 ? Uri.UnescapeDataString(kv[1]) : string.Empty;
		}

		return null;
	}
}

<style>
/* GitHub-ish neutral look (not a copy) */
:root {
	--bg: #ffffff;
	--surface: #ffffff;
	--panel: #ffffff;
	--border: rgba(148, 163, 184, .25);
	--text: #e5e7eb;
	--muted: rgba(229, 231, 235, .75);
	--muted2: rgba(229, 231, 235, .55);
	--primary: #238636;
	--primaryHover: #2ea043;
	--disabled: rgba(148, 163, 184, .12);
}

.page, .landing {
	min-height: calc(100vh - 40px);
	display: grid;
	place-content: start center;
	padding: 42px 16px;
	background: radial-gradient(1200px 700px at 50% -200px, rgba(59, 130, 246, .15), transparent 60%), var(--bg);
	color: var(--text);
}

.brand {
	display: flex;
	align-items: center;
	gap: 12px;
	justify-content: center;
	margin-bottom: 16px;
}

.brand-mark {
	width: 40px;
	height: 40px;
	display: grid;
	place-items: center;
	border-radius: 12px;
	border: 1px solid var(--border);
	background: rgba(15, 23, 42, .65);
	font-size: 18px;
}

.brand-name { font-weight: 700; letter-spacing: .2px; line-height: 1.1; }
.brand-sub { color: var(--muted2); font-size: 12px; margin-top: 2px; }

.title, .h1 {
	text-align: center;
	font-size: 24px;
	margin: 8px 0 18px;
	font-weight: 700;
}

.panel, .landing-card {
	width: min(420px, 92vw);
	border: 1px solid var(--border);
	border-radius: 14px;
	background: rgba(11, 18, 32, .75);
	backdrop-filter: blur(8px);
	padding: 16px;
	box-shadow: 0 18px 50px rgba(0, 0, 0, .45);
}

.btn {
	width: 100%;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	gap: 10px;
	height: 42px;
	border-radius: 10px;
	border: 1px solid var(--border);
	background: transparent;
	color: var(--text);
	text-decoration: none;
	font-weight: 600;
	cursor: pointer;
	margin-top: 10px;
}

.btn-icon {
	width: 26px;
	height: 26px;
	display: grid;
	place-items: center;
	border-radius: 8px;
	background: rgba(148, 163, 184, .10);
	border: 1px solid rgba(148, 163, 184, .20);
	font-size: 12px;
}

.btn-primary {
	margin-top: 0;
	border-color: rgba(46, 160, 67, .45);
	background: linear-gradient(180deg, rgba(46, 160, 67, .95), rgba(35, 134, 54, .95));
}

.btn-primary:hover {
	background: linear-gradient(180deg, rgba(46, 160, 67, 1), rgba(46, 160, 67, 1));
	border-color: rgba(46, 160, 67, .70);
}

.btn-disabled {
	background: var(--disabled);
	color: var(--muted2);
	cursor: not-allowed;
}

.pill {
	margin-left: 6px;
	font-size: 11px;
	padding: 2px 8px;
	border-radius: 999px;
	border: 1px solid rgba(148, 163, 184, .25);
	color: var(--muted2);
}

.fineprint {
	margin-top: 12px;
	font-size: 12px;
	color: var(--muted2);
	text-align: center;
	line-height: 1.4;
}

.lead {
	color: var(--muted);
	line-height: 1.6;
	margin: 10px 0 18px;
	text-align: left;
}

.info {
	border: 1px solid var(--border);
	border-radius: 12px;
	padding: 12px;
	background: rgba(15, 23, 42, .45);
}

.info-title { font-weight: 700; margin-bottom: 6px; }
.info-text { color: var(--muted); line-height: 1.6; font-size: 13px; }

.btn-link {
	display: inline-block;
	margin-top: 14px;
	color: rgba(96, 165, 250, .95);
	text-decoration: none;
}

.btn-link:hover { text-decoration: underline; }

code {
	padding: 2px 6px;
	border-radius: 8px;
	border: 1px solid rgba(148, 163, 184, .20);
	background: rgba(15, 23, 42, .45);
	color: rgba(229, 231, 235, .92);
}
</style>