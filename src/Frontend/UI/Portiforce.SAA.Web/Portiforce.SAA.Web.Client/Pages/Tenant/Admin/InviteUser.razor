@page "/tenant/admin/users/invite"
@using Portiforce.SAA.Contracts.Models.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Services.Interfaces

@* 1. Protection at the Routing Level *@
@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode InteractiveWebAssembly

@inject IAdminApiClient ApiClient
@inject NavigationManager Nav

<PageTitle>Invite User</PageTitle>

<div class="container mt-4">
    <h3>Invite New User</h3>
    <p class="text-muted">Send an invitation email to add a user to your tenant.</p>

    <EditForm Model="@inviteModel" OnValidSubmit="HandleInvite">
        <DataAnnotationsValidator />

        <div class="card p-4 shadow-sm">
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <InputText @bind-Value="inviteModel.Email" class="form-control" placeholder="colleague@example.com" />
                <ValidationMessage For="@(() => inviteModel.Email)" />
            </div>

           <div class="d-flex justify-content-end gap-2">
                <a href="/tenant/admin/users" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-envelope"></i> Send Invite
                </button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    private CreateInviteRequest inviteModel = new();

    private async Task HandleInvite()
    {
        await ApiClient.InviteUserAsync(inviteModel);
        Nav.NavigateTo("/tenant/admin/users");
    }
}