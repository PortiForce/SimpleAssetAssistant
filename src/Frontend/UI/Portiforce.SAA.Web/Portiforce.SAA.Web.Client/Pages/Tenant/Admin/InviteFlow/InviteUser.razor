@page "/admin/invites/new"

@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Contracts.Configuration
@using Portiforce.SAA.Contracts.Enums
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Extensions
@using Portiforce.SAA.Web.Client.Models.Tenant.Admin.InviteFlow
@using Portiforce.SAA.Web.Client.Services.Interfaces

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode InteractiveWebAssembly

@inject IAdminApiClient ApiClient
@inject NavigationManager Nav

@inject IStringLocalizer<InviteUser> L
@inject IStringLocalizer<SharedEnumResources> SharedEnumL
@inject IStringLocalizer<SharedActionResources> SharedActionL

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-0">@L["HeaderTitle"]</h3>
        <p class="text-muted">@L["HeaderDescription"].</p>
    </div>
    <a class="btn btn-outline-secondary" href="@UiRoutes.AdminRoutes.Invites.List">@L["ActionTextBackToInvites"]</a>
</div>

<div class="container mt-4">
    <EditForm Model="@inviteModel" OnValidSubmit="HandleInvite">
        <DataAnnotationsValidator />

        <div class="card p-4 shadow-sm">
            <div class="row g-3">

                <div class="mb-3">
                    <label class="form-label fw-bold">@L["LabelInviteChannel"]</label>
                    <InputSelect @bind-Value="inviteModel.Channel"
                                 @bind-Value:after="OnChannelChanged"
                                 class="form-select">
                        @foreach (InviteChannel channel in InviteEnumExtensions.ChannelOptions)
                        {
                            <option value="@channel">@channel.ToDisplayName(SharedEnumL)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => inviteModel.Channel)" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">@CurrentChannelInfo.Label</label>
                    <InputText @bind-Value="inviteModel.TargetValue"
                               class="form-control"
                               placeholder="@CurrentChannelInfo.Placeholder" />
                    <div class="form-text">@CurrentChannelInfo.HelpText</div>
                    <ValidationMessage For="@(() => inviteModel.TargetValue)" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">@L["LabelIntendedRole"]</label>
                    <InputSelect @bind-Value="inviteModel.IntendedRole" class="form-select">
                        @foreach (InviteTenantRole role in InviteEnumExtensions.RoleOptions)
                        {
                            <option value="@role">@role.ToDisplayName(SharedEnumL)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => inviteModel.IntendedRole)" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">@L["LabelAccountTier"]</label>
                    <InputSelect @bind-Value="inviteModel.IntendedTier" class="form-select">
                        @foreach (InviteAccountTier tier in InviteEnumExtensions.TierOptions)
                        {
                            <option value="@tier">@tier.ToDisplayName(SharedEnumL)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => inviteModel.IntendedTier)" />
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="@UiRoutes.AdminRoutes.Invites.List" class="btn btn-outline-secondary">@SharedActionL["ButtonCancel"]</a>
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    <i class="bi bi-envelope"></i>
                    @(isSubmitting? L["MessageInfoSending"] : L["MessageInfoSendInvite"])
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger mt-3 mb-0">@error</div>
            }
        </div>
    </EditForm>
</div>

@code {
    private CreateInviteRequest inviteModel = new()
    {
        Channel = InviteChannel.Email,
        IntendedRole = InviteTenantRole.TenantUser,
        IntendedTier = InviteAccountTier.Investor,
        TargetValue = string.Empty
    };

    private bool isSubmitting;
    private string? error;

    private InviteChannelUiInfo CurrentChannelInfo => inviteModel.Channel switch
    {
        InviteChannel.Email => new(InviteChannel.Email.ToDisplayName(SharedEnumL), "colleague@example.com", L["HelpTextEmail"]),
        InviteChannel.Telegram => new(InviteChannel.Telegram.ToDisplayName(SharedEnumL), "@nickname", L["HelpTextTelegram"]),
        InviteChannel.AppleId => new(InviteChannel.AppleId.ToDisplayName(SharedEnumL), "name@icloud.com", L["HelpTextAppleId"]),
        _ => new(L["LabelDefaultValue"], string.Empty, string.Empty)
    };

    private void OnChannelChanged()
    {
        inviteModel.TargetValue = string.Empty;
        error = null;
    }

    private async Task HandleInvite()
    {
        error = null;
        isSubmitting = true;

        try
        {
           CreateInviteResponse response = await ApiClient.InviteUserAsync(inviteModel);
        
            // Example: You could show a toast notification here with response.InviteId
            Nav.NavigateTo(UiRoutes.AdminRoutes.Invites.List);
        }
        catch (Exception ex)
        {
            // Because of our ApiClient update, 'ex.Message' will now hold 
            // the exact business logic error (e.g., "Unsupported role or tier.") 
            // returned by the Minimal API!
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}