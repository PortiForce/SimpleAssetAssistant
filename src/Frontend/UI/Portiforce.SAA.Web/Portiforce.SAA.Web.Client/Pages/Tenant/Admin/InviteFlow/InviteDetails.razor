@page "/admin/invites/{InviteId:guid}"

@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Contracts.Configuration
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Extensions
@using Portiforce.SAA.Web.Client.Services.Interfaces
@using Portiforce.SAA.Web.Client.Shared

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IAdminApiClient AdminApiClient
@inject IStringLocalizer<InviteDetails> L
@inject IStringLocalizer<SharedActionResources> SharedActionL
@inject IStringLocalizer<SharedEnumResources> SharedEnumL

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-0">@L["PageTitle"]</h3>
        <div class="text-muted small">@L["LabelId"]: @InviteId</div>
    </div>

    <a class="btn btn-outline-secondary" href="@UiRoutes.AdminRoutes.Invites.List">
        @L["ActionTextBackToInvites"]
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (isLoading)
{
    <div class="text-muted">@L["MessageInfoLoadingInviteDetails"]</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else if (invite is null)
{
    <div class="alert alert-warning">@L["MessageErrorCouldNotLoadInviteDetails"]</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="h5 mb-1">@invite.InviteTargetValue</div>
                    <div class="text-muted">
                        <div>
                            <span>@L["LabelChannel"]:</span>
                            @invite.InviteChannel.ToDisplayName(SharedEnumL)
                        </div>
                        <div>
                            <span>@L["LabelRole"]:</span>
                            @invite.InviteRole.ToDisplayName(SharedEnumL)
                        </div>
                        <div>
                            <span>@L["LabelTier"]:</span>
                            @invite.InviteTier.ToDisplayName(SharedEnumL)
                        </div>
                    </div>
                    <div>
                        <span>@L["LabelAlias"]:</span>
                        @invite.Alias
                    </div>
                </div>

                <span class="badge @invite.State.ToCssBadgeClass()">
                    @invite.State.ToDisplayName(SharedEnumL)
                </span>
            </div>

            <hr />

            <dl class="row mb-0">
                <dt class="col-sm-3">@L["LabelCreatedAt"]</dt>
                <dd class="col-sm-9">@invite.CreatedAtUtc.ToUiDateTime()</dd>

                <dt class="col-sm-3">@L["LabelExpiresAt"]</dt>
                <dd class="col-sm-9">@invite.ExpiresAtUtc.ToUiDateTime()</dd>

                <dt class="col-sm-3">@L["LabelInvitedBy"]</dt>
                <dd class="col-sm-9">@invite.InvitedBy</dd>

                <dt class="col-sm-3">@L["LabelSendCount"]</dt>
                <dd class="col-sm-9">@invite.SendTimesCount</dd>

                <dt class="col-sm-3">@L["LabelAcceptedAt"]</dt>
                <dd class="col-sm-9">@(invite.AcceptedAtUtc?.ToUiDateTime() ?? L["EmptyValue"])</dd>

                <dt class="col-sm-3">@L["LabelRelatedAccountId"]</dt>
                <dd class="col-sm-9">@(invite.RelatedAccountId?.ToString() ?? L["EmptyValue"])</dd>
            </dl>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4 p-3 pt-0">
            @if (invite.CanResend)
            {
                <a class="btn btn-sm btn-outline-primary @(isRevoking ? "disabled" : null)"
                       href="@(isRevoking ? null : ApiRoutes.AdminInviteRoutes.InviteResend(InviteId))"
                       aria-disabled="@isRevoking">
                    @SharedActionL["ActionResend"]
                </a>
            }

            @if (invite.CanRevoke)
            {
                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        disabled="@isRevoking"
                        @onclick="RevokeInviteAsync">
                    @(isRevoking? L["ActionRevokeInProgress"] : SharedActionL["ActionRevoke"])
                </button>
            }
        </div>
    </div>
}

<ConfirmPopup @ref="revokeInviteConfirm"
              Title="@L["TitleConfirmRevokeInvite"].Value"
              Description="@L["DescriptionConfirmRevokeInvite"].Value"
              ConfirmButtonText="@SharedActionL["ActionRevoke"].Value"
              ConfirmButtonClass="btn-danger" />

@code {
    [Parameter]
    public Guid InviteId { get; set; }

    private ConfirmPopup? revokeInviteConfirm;
    private AdminInviteDetailsResponse? invite;
    private bool isLoading = true;
    private bool isRevoking;
    private string? error;
    private string? successMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            invite = await AdminApiClient.GetInviteDetailsAsync(InviteId);
        }
        catch
        {
            invite = null;
            error = L["MessageErrorCouldNotLoadInviteDetails"];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RevokeInviteAsync()
    {
        if (isRevoking || invite is null || !invite.CanRevoke)
        {
            return;
        }

        if (revokeInviteConfirm is null || !await revokeInviteConfirm.ShowAsync(L["ConfirmRevokeInviteTitle"], L["ConfirmRevokeInviteDescription"]))
        {
            return;
        }

        try
        {
            isRevoking = true;
            error = null;
            successMessage = null;

            await AdminApiClient.RevokeInviteAsync(InviteId);

            await LoadAsync();

            successMessage = L["InfoInviteRevoked"];
        }
        catch
        {
            error = L["InfoCouldNotRevokeInvite"];
        }
        finally
        {
            isRevoking = false;
        }
    }
}
