@page "/admin/invites/{InviteId:guid}"

@using Portiforce.SAA.Contracts.Configuration
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Services.Interfaces

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IAdminApiClient ApiClient

@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Web.Client.Extensions
@inject IStringLocalizer<InviteDetails> L
@inject IStringLocalizer<SharedActionResources> SharedActionL
@inject IStringLocalizer<SharedEnumResources> SharedEnumL

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-0">@L["PageTitle"]</h3>
        <div class="text-muted small">@L["LabelId"]: @InviteId</div>
    </div>

    <a class="btn btn-outline-secondary" href="@UiRoutes.AdminRoutes.Invites.List">@L["ActionTextBackToInvites"]</a>
</div>

@if (isLoading)
{
    <div class="text-muted">@L["MessageInfoLoadingInviteDetails"]</div>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else if (invite is null)
{
    <div class="alert alert-warning">@L["MessageErrorCouldNotLoadInviteDetails"]</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="h5 mb-1">@invite.InviteTargetValue</div>
                    <div class="text-muted">
                        <div>
                            <span>@L["LabelChannel"]:</span>
                            @invite.InviteChannel.ToDisplayName(SharedEnumL)
                        </div>
                        <div>
                            <span>@L["LabelRole"]:</span>
                            @invite.InviteRole.ToDisplayName(SharedEnumL)
                        </div>
                        <div>
                            <span>@L["LabelTier"]:</span>
                            @invite.InviteTier.ToDisplayName(SharedEnumL)
                        </div>
                    </div>
                </div>

                <span class="badge @invite.State.ToCssBadgeClass())">
                    @invite.State.ToDisplayName(SharedEnumL)
                </span>
            </div>

            <hr />

            <dl class="row mb-0">
                <dt class="col-sm-3">@L["LabelCreated"]</dt>
                <dd class="col-sm-9">@invite.CreatedAtUtc.ToUiDateTime()</dd>

                <dt class="col-sm-3">@L["LabelExpires"]</dt>
                <dd class="col-sm-9">@invite.ExpiresAtUtc.ToUiDateTime()</dd>

                <dt class="col-sm-3">@L["LabelInvitedBy"]</dt>
                <dd class="col-sm-9">@invite.InvitedBy</dd>

                <dt class="col-sm-3">@L["LabelSendCount"]</dt>
                <dd class="col-sm-9">@invite.SendTimesCount</dd>

                <dt class="col-sm-3">@L["LabelAccepted"]</dt>
                <dd class="col-sm-9">@(invite.AcceptedAtUtc?.ToUiDateTime() ?? L["EmptyValue"])</dd>

                <dt class="col-sm-3">@L["LabelRelatedAccountId"]</dt>
                <dd class="col-sm-9">@(invite.RelatedAccountId?.ToString() ?? L["EmptyValue"])</dd>
            </dl>
        </div>
        <div class="card-actions">
            @if (invite.CanResend)
            {
                <a class="action-default" href="@ApiRoutes.AdminInviteRoutes.InviteResend(InviteId)">@SharedActionL["ActionResend"]</a>
            }
            @if (invite.CanRevoke)
            {
                <a class="action-caution" href="@ApiRoutes.AdminInviteRoutes.InviteRevoke(InviteId)">@SharedActionL["ActionRevoke"]</a>
            }
        </div>
    </div>
    
}

@code {
    [Parameter]
    public Guid InviteId { get; set; }

    private AdminInviteDetailsResponse? invite;
    private bool isLoading = true;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            invite = await ApiClient.GetInviteDetailsAsync(InviteId);
        }
        catch (Exception ex)
        {
            invite = null;
            error = string.Format(L["MessageErrorCouldNotLoadInviteDetails"], ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}