@page "/admin/invites"

@using Portiforce.SAA.Contracts.Enums
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Services.Interfaces

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@* Essential: Tells Blazor to run this interactively in the browser to fetch data *@
@rendermode InteractiveWebAssembly

@inject IAdminApiClient ApiClient

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Invites</h3>
    @* A handy link to the page we built earlier! *@
    <a href="/admin/invites/new" class="btn btn-primary">Invite User</a>
</div>

@if (isLoading)
{
    <div class="text-muted">Loading invites...</div>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else if (invitesData?.Items is not null && invitesData.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Target</th>
                    <th>Channel</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invite in invitesData.Items)
                {
                    <tr>
                        <td class="fw-bold">@invite.InviteTargetValue</td>
                        <td>@invite.InviteChannel</td>
                        <td>@invite.InviteRole</td>
                        <td>
                            @* Simple badge styling based on standard status names *@
                            <span class="badge @(invite.Status == InviteStatus.Pending ? "bg-warning text-dark" : "bg-secondary")">
                                @invite.Status
                            </span>
                        </td>
                        <td>
                            @* Link to your details page, passing the ID *@
                            <a href="/admin/invites/@invite.Id" class="btn btn-sm btn-outline-primary">
                                Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">No invites found.</div>
}

@code {
    private InviteListResponse? invitesData;
    private bool isLoading = true;
    private string? error;

    private string search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            // Define minimal request parameters (Page 1, 20 items)
            var request = new GetInviteListQueryRequest(search, null, null, 1, 20);
           
            invitesData = await ApiClient.GetInvitesAsync(request);
        }
        catch (Exception ex)
        {
            error = "Could not load invites: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}