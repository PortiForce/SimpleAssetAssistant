@page "/admin/invites"

@using Microsoft.AspNetCore.Components.QuickGrid
@using Portiforce.SAA.Contracts.Configuration
@using Portiforce.SAA.Contracts.Enums
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Services.Interfaces
@using Portiforce.SAA.Web.Client.Shared

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IAdminApiClient ApiClient
@inject IJSRuntime JSRuntime

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Invites</h3>
</div>

<div class="container card p-4 shadow-sm">
    <div class="actions-area-top mb-3">
        <a href="@UiRoutes.AdminRoutes.Invites.New" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Invite User
        </a>
    </div>

    <form @onsubmit="ApplySearchAsync" class="row g-2 mb-3 data-manipulation-area align-items-end">
    
        <div class="col-md-3">
            <label class="form-label">Search targets</label>
            <input class="form-control"
                   placeholder="Search targets..."
                   @bind="searchText" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Channels</label>
            <DropdownCheckboxList TItem="InviteChannel"
                                  Items="channelOptions"
                                  SelectedValues="selectedChannels"
                                  SelectedValuesChanged="OnSelectedChannelsChanged"
                                  ButtonText="All Channels"
                                  ItemTextSelector="GetChannelDisplayName" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Statuses</label>
            <DropdownCheckboxList TItem="InviteStatus"
                                  Items="statusOptions"
                                  SelectedValues="selectedStatuses"
                                  SelectedValuesChanged="OnSelectedStatusesChanged"
                                  ButtonText="All Statuses"
                                  ItemTextSelector="GetStatusDisplayName" />
        </div>
        
        <div class="col-md-2">
            <label class="form-label">Account filter</label>
            <select class="form-select" @bind="SearchHasAccountString">
                <option value="">Any option</option>
                <option value="true">Only with account</option>
                <option value="false">Only without account</option>
            </select>
        </div>

        <div class="col-md-auto ms-auto d-flex gap-2 justify-content-end">
            <button type="submit" class="btn btn-outline-primary" disabled="@isBusy">
                Search
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="ClearSearchAsync" disabled="@isBusy">
                Clear
            </button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="invites-grid-wrapper position-relative">

        @if (isBusy)
        {
            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center"
                 style="background: rgba(255,255,255,0.7); z-index: 10;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }

        <QuickGrid TGridItem="InviteListItemResponse"
                   @ref="grid"
                   ItemsProvider="invitesProvider"
                   Class="table table-striped table-hover align-middle"
                   Pagination="paginationState">

            <PropertyColumn Property="x => x.InviteTargetValue" Title="Target" />

            <TemplateColumn Title="Status" Context="item">
                <span class="badge @(GetStatusBadge(item.Status))">
                    @item.Status
                </span>
                @if (item.RelatedAccountId.HasValue)
                {
                    <i class="bi bi-person-check-fill text-success ms-2" title="Has valid account"></i>
                }
            </TemplateColumn>

            <PropertyColumn Property="x => x.InviteChannel" Title="Channel" />
            <PropertyColumn Property="x => x.InviteRole" Title="Role" />

            <TemplateColumn Title="Actions" Context="item">
                <div class="d-flex gap-2 flex-wrap">
                    <a href="@UiRoutes.AdminRoutes.Invites.Details(item.Id)" class="btn btn-sm btn-outline-primary">
                        Details
                    </a>

                    @if (item.CanResend)
                    {
                        <a href="@UiRoutes.AdminRoutes.Invites.InviteResend(item.Id)" class="btn btn-sm btn-outline-primary">
                            Resend
                        </a>
                    }

                    @if (item.CanRevoke)
                    {
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => RevokeInviteAsync(item.Id)"
                                disabled="@isBusy">
                            Revoke
                        </button>
                    }
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
        <div class="text-muted small">
            @if (totalCount > 0)
            {
                <span>
                    Showing page @(paginationState.CurrentPageIndex + 1) of @TotalPages (@totalCount total)
                </span>
            }
        </div>

        <Paginator State="paginationState" />
    </div>

    @if (!isBusy && totalCount == 0 && string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-info mt-3">No invites found matching your criteria.</div>
    }
</div>

@code {
    private const int DefaultPageSize = 20;

    private readonly PaginationState paginationState = new() { ItemsPerPage = DefaultPageSize };
    private QuickGrid<InviteListItemResponse>? grid;
    private GridItemsProvider<InviteListItemResponse> invitesProvider = default!;

    private static readonly IReadOnlyList<InviteChannel> channelOptions =
    [
        InviteChannel.Email,
        InviteChannel.Telegram,
        InviteChannel.AppleId
    ];

    private static readonly IReadOnlyList<InviteStatus> statusOptions =
    [
        InviteStatus.Pending,
        InviteStatus.Accepted,
        InviteStatus.Revoked,
        InviteStatus.Expired
    ];

    // UI input bindings
    private string searchText = string.Empty;
    private HashSet<InviteChannel> selectedChannels = [];
    private HashSet<InviteStatus> selectedStatuses = [];
    private bool? searchHasAccount = null;

    // Applied filters
    private string appliedSearchText = string.Empty;
    private HashSet<InviteChannel> appliedChannels = [];
    private HashSet<InviteStatus> appliedStatuses = [];
    private bool? appliedHasAccount = null;

    private bool isBusy;
    private string? error;
    private int totalCount;

    private int TotalPages => totalCount <= 0
        ? 0
        : (int)Math.Ceiling(totalCount / (double)paginationState.ItemsPerPage);

    protected override void OnInitialized()
    {
        invitesProvider = async request =>
        {
            isBusy = true;
            error = null;
            _ = InvokeAsync(StateHasChanged);

            try
            {
                int pageSize = request.Count ?? paginationState.ItemsPerPage;
                int page = (request.StartIndex / pageSize) + 1;

                var apiRequest = new GetInviteListQueryRequest(
                    Search: appliedSearchText,
                    Statuses: appliedStatuses.Count > 0 ? appliedStatuses : null,
                    Channels: appliedChannels.Count > 0 ? appliedChannels : null,
                    HasAccount: appliedHasAccount,
                    Page: page,
                    PageSize: pageSize);

                InviteListResponse response = await ApiClient.GetInvitesAsync(apiRequest, request.CancellationToken);
                totalCount = response.TotalCount;

                return GridItemsProviderResult.From(response.Items.ToList(), response.TotalCount);
            }
            catch (OperationCanceledException)
            {
                return GridItemsProviderResult.From(Array.Empty<InviteListItemResponse>(), totalCount);
            }
            catch (Exception ex)
            {
                totalCount = 0;
                error = "Could not load invites: " + ex.Message;
                return GridItemsProviderResult.From(Array.Empty<InviteListItemResponse>(), 0);
            }
            finally
            {
                isBusy = false;
                _ = InvokeAsync(StateHasChanged);
            }
        };
    }

    private string SearchHasAccountString
    {
        get => searchHasAccount switch { true => "true", false => "false", _ => "" };
        set => searchHasAccount = value switch { "true" => true, "false" => false, _ => null };
    }

    private Task OnSelectedChannelsChanged(HashSet<InviteChannel> values)
    {
        selectedChannels = values;
        return Task.CompletedTask;
    }

    private Task OnSelectedStatusesChanged(HashSet<InviteStatus> values)
    {
        selectedStatuses = values;
        return Task.CompletedTask;
    }

    private async Task ApplySearchAsync()
    {
        appliedSearchText = searchText.Trim();
        appliedChannels = [.. selectedChannels];
        appliedStatuses = [.. selectedStatuses];
        appliedHasAccount = searchHasAccount;

        await RefreshGridAsync();
    }

    private async Task ClearSearchAsync()
    {
        searchText = string.Empty;
        selectedChannels.Clear();
        selectedStatuses.Clear();
        searchHasAccount = null;

        appliedSearchText = string.Empty;
        appliedChannels.Clear();
        appliedStatuses.Clear();
        appliedHasAccount = null;

        await RefreshGridAsync();
    }

    private async Task RefreshGridAsync()
    {
        if (paginationState.CurrentPageIndex != 0)
        {
            await paginationState.SetCurrentPageIndexAsync(0);
        }
        else if (grid is not null)
        {
            await grid.RefreshDataAsync();
        }
    }

    private async Task RevokeInviteAsync(Guid inviteId)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to revoke this invite?");
        if (!confirm)
        {
            return;
        }

        try
        {
            isBusy = true;
            error = null;

            await ApiClient.RevokeInviteAsync(inviteId);

            if (grid is not null)
            {
                await grid.RefreshDataAsync();
            }
        }
        catch (Exception ex)
        {
            error = "Could not revoke invite: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private static string GetChannelDisplayName(InviteChannel channel) => channel switch
    {
        InviteChannel.Email => "Email",
        InviteChannel.Telegram => "Telegram",
        InviteChannel.AppleId => "Apple ID",
        _ => channel.ToString()
    };

    private static string GetStatusDisplayName(InviteStatus status) => status switch
    {
        InviteStatus.Pending => "Pending",
        InviteStatus.Accepted => "Accepted",
        InviteStatus.Revoked => "Revoked",
        InviteStatus.Expired => "Expired",
        _ => status.ToString()
    };

    private static string GetStatusBadge(InviteStatus status) => status switch
    {
        InviteStatus.Pending => "bg-warning text-dark",
        InviteStatus.Accepted => "bg-success",
        InviteStatus.Revoked => "bg-danger",
        InviteStatus.Expired => "bg-dark",
        _ => "bg-secondary"
    };
}