@page "/admin/invites"

@using Portiforce.SAA.Contracts.Configuration
@using Portiforce.SAA.Contracts.Enums
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Services.Interfaces
@using Microsoft.AspNetCore.Components.QuickGrid

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IAdminApiClient ApiClient
@inject IJSRuntime JSRuntime

<style>
    /* Hide any placeholder rows QuickGrid marks as hidden */
    ::deep tbody tr[aria-hidden="true"] {
        display: none;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Invites</h3>
</div>

<div class="container card-body">
    <div class="actions-area-top">
        <a href="@UiRoutes.AdminRoutes.Invites.New" class="btn btn-primary">Invite User</a>
    </div>

    <div class="row g-2 mb-3 mt-2 data-manipulation-area">
        <div class="col-md-4">
            <input class="form-control"
                   placeholder="Search..."
                   @bind="search"
                   @bind:event="oninput" />
        </div>
        <div class="col-auto ">
            <button class="btn btn-outline-primary" @onclick="ReloadAsync" disabled="@isLoading">
                Search
            </button>
        </div>
        <div class="col-auto ">
            <button class="btn btn-outline-primary" @onclick="ClearSearchAsync" disabled="@isLoading">
                Clear
            </button>
        </div>
    </div>
    @if (isLoading)
    {
        <div class="text-muted">Loading invites...</div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    else if (invitesData?.Items is { Count: > 0 })
    {
        <div class="card-body">
            <QuickGrid TGridItem="InviteListItemResponse"
                       Items="invitesData.Items.AsQueryable()"
                       Class="table table-striped table-hover align-middle"
                       Pagination="paginationState">
                <PropertyColumn Property="x => x.InviteTargetValue" Title="Target" Sortable="true"/>
                <PropertyColumn Property="x => x.InviteChannel" Title="Channel" Sortable="true"/>
                <PropertyColumn Property="x => x.InviteRole" Title="Role" Sortable="true"/>

                <TemplateColumn Title="Status" Context="item">
                    <span class="badge @(GetStatusBadge(item.Status))">
                        @item.Status
                    </span>
                </TemplateColumn>

                <TemplateColumn Title="Actions" Context="item">
                    <a href="@UiRoutes.AdminRoutes.Invites.Details(item.Id)"
                       class="btn btn-sm btn-outline-primary">
                        Details
                    </a>
                    @if (item.CanResend)
                    {
                        <a href="@UiRoutes.AdminRoutes.Invites.InviteResend(item.Id)"
                           class="btn btn-sm btn-outline-primary">
                            Resend
                        </a>
                    }
                    @if (item.CanRevoke)
                    {
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => RevokeInviteAsync(item.Id)"
                                disabled="@isLoading">
                            Revoke
                        </button>
                    }
                </TemplateColumn>
            </QuickGrid>
        </div>
        <div class="card-footer">
            <Paginator State="paginationState" />
        </div>
    }
    else
    {
        <div class="alert alert-info">No invites found.</div>
    }
    <div class="actions-area-bottom">
        <a href="@UiRoutes.AdminRoutes.Invites.New" class="btn btn-primary">Invite User</a>
    </div>
</div>

@code {

    PaginationState paginationState = new PaginationState() { ItemsPerPage = 20 };
            
    private InviteListResponse? invitesData;
    private bool isLoading = true;
    private string? error;

    private string search = string.Empty;
    private int pageNumber = 1;
    private int pageSize = 20;

    private bool CanGoNext =>
        invitesData is not null &&
        pageNumber * pageSize < invitesData.TotalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task ReloadAsync()
    {
        if (string.IsNullOrWhiteSpace(search))
        {
            // do nothing if search is empty
            return;
        }
        pageNumber = 1;
        await LoadDataAsync();
    }

    private async Task ClearSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(search))
        {
            return;
        }
        search = string.Empty;
        pageNumber = 1;
        await LoadDataAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (pageNumber <= 1)
        {
            return;
        }

        pageNumber--;
        await LoadDataAsync();
    }

    private async Task NextPageAsync()
    {
        if (!CanGoNext)
        {
            return;
        }

        pageNumber++;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            var request = new GetInviteListQueryRequest(
                search,
                null,
                null,
                pageNumber,
                pageSize);

            invitesData = await ApiClient.GetInvitesAsync(request);
        }
        catch (Exception ex)
        {
            invitesData = null;
            error = "Could not load invites: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RevokeInviteAsync(Guid inviteId)
    {
        var confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to revoke this invite?");
        if (!confirm)
        {
            return;
        }
        try
        {
            isLoading = true;
            error = null;
            await ApiClient.RevokeInviteAsync(inviteId);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            error = "Could not revoke invite: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string GetStatusBadge(InviteStatus status) => status switch
    {
        InviteStatus.Pending => "bg-warning text-dark",
        InviteStatus.Accepted => "bg-success",
        InviteStatus.Revoked => "bg-secondary",
        InviteStatus.Expired => "bg-dark",
        _ => "bg-secondary"
    };
}