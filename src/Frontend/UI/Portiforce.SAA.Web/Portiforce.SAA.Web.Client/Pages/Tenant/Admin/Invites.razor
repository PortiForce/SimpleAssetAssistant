@page "/admin/invites"

@using Microsoft.AspNetCore.Components.QuickGrid
@using Portiforce.SAA.Contracts.Configuration
@using Portiforce.SAA.Contracts.Enums
@using Portiforce.SAA.Contracts.Models.Client.Invite
@using Portiforce.SAA.Contracts.UiSetup
@using Portiforce.SAA.Web.Client.Services.Interfaces

@attribute [Authorize(Policy = UiPolicies.TenantAdmin)]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject IAdminApiClient ApiClient
@inject IJSRuntime JSRuntime

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Invites</h3>
</div>

<div class="container card p-4 shadow-sm">
    <div class="actions-area-top mb-3">
        <a href="@UiRoutes.AdminRoutes.Invites.New" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Invite User
        </a>
    </div>

    <div class="row g-2 mb-3 data-manipulation-area">
        <div class="col-md-4">
            <input class="form-control"
                   placeholder="Search targets..."
                   @bind="searchText"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDownAsync" />
        </div>

        <div class="col-auto">
            <button class="btn btn-outline-primary"
                    @onclick="ApplySearchAsync"
                    disabled="@isBusy">
                Search
            </button>
        </div>

        <div class="col-auto">
            <button class="btn btn-outline-secondary"
                    @onclick="ClearSearchAsync"
                    disabled="@(isBusy || (string.IsNullOrEmpty(searchText) && string.IsNullOrEmpty(appliedSearchText)))">
                Clear
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="invites-grid-wrapper position-relative">
        
        @if (isBusy)
        {
            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center" style="background: rgba(255,255,255,0.7); z-index: 10;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }

        @* REMOVED the ItemKey lambda to stop the infinite loop! *@
        <QuickGrid TGridItem="InviteListItemResponse"
                   @ref="grid"
                   ItemsProvider="invitesProvider"
                   Class="table table-striped table-hover align-middle"
                   Pagination="paginationState">
            
            <PropertyColumn Property="x => x.InviteTargetValue" Title="Target" />
            <PropertyColumn Property="x => x.InviteChannel" Title="Channel" />
            <PropertyColumn Property="x => x.InviteRole" Title="Role" />

            <TemplateColumn Title="Status" Context="item">
                <span class="badge @(GetStatusBadge(item.Status))">
                    @item.Status
                </span>
            </TemplateColumn>

            <TemplateColumn Title="Actions" Context="item">
                <div class="d-flex gap-2 flex-wrap">
                    <a href="@UiRoutes.AdminRoutes.Invites.Details(item.Id)" class="btn btn-sm btn-outline-primary">
                        Details
                    </a>

                    @if (item.CanResend)
                    {
                        <a href="@UiRoutes.AdminRoutes.Invites.InviteResend(item.Id)" class="btn btn-sm btn-outline-primary">
                            Resend
                        </a>
                    }

                    @if (item.CanRevoke)
                    {
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => RevokeInviteAsync(item.Id)"
                                disabled="@isBusy">
                            Revoke
                        </button>
                    }
                </div>
            </TemplateColumn>
        </QuickGrid>
    </div>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
        <div class="text-muted small">
            @if (totalCount > 0)
            {
                <span>
                    Showing page @(paginationState.CurrentPageIndex + 1) of @TotalPages (@totalCount total)
                </span>
            }
        </div>

        <Paginator State="paginationState" />
    </div>

    @if (!isBusy && totalCount == 0 && string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-info mt-3">No invites found matching your criteria.</div>
    }
</div>

@code {
    private const int DefaultPageSize = 10;

    private readonly PaginationState paginationState = new() { ItemsPerPage = DefaultPageSize };
    private QuickGrid<InviteListItemResponse>? grid;
    private GridItemsProvider<InviteListItemResponse> invitesProvider = default!;

    private string searchText = string.Empty;
    private string appliedSearchText = string.Empty;

    private bool isBusy;
    private string? error;
    private int totalCount;

    private int TotalPages => totalCount <= 0 ? 0 : (int)Math.Ceiling(totalCount / (double)paginationState.ItemsPerPage);

    protected override void OnInitialized()
    {
        invitesProvider = async request =>
        {
            isBusy = true;
            error = null;
            _ = InvokeAsync(StateHasChanged);

            try
            {
                int pageSize = request.Count ?? paginationState.ItemsPerPage;
                int pageNumber = (request.StartIndex / pageSize) + 1;

                var apiRequest = new GetInviteListQueryRequest(
                    appliedSearchText, null, null, pageNumber, pageSize);

                InviteListResponse response = await ApiClient.GetInvitesAsync(apiRequest, request.CancellationToken);
                totalCount = response.TotalCount;

                return GridItemsProviderResult.From(response.Items.ToList(), response.TotalCount);
            }
            catch (OperationCanceledException)
            {
                return GridItemsProviderResult.From(Array.Empty<InviteListItemResponse>(), totalCount);
            }
            catch (Exception ex)
            {
                totalCount = 0;
                error = "Could not load invites: " + ex.Message;
                return GridItemsProviderResult.From(Array.Empty<InviteListItemResponse>(), 0);
            }
            finally
            {
                isBusy = false;
                _ = InvokeAsync(StateHasChanged);
            }
        };
    }

    private async Task ApplySearchAsync()
    {
        appliedSearchText = searchText.Trim();
        
        if (paginationState.CurrentPageIndex != 0)
        {
            await paginationState.SetCurrentPageIndexAsync(0);
        }
        else if (grid is not null)
        {
            await grid.RefreshDataAsync();
        }
    }

    private async Task ClearSearchAsync()
    {
        searchText = string.Empty;
        appliedSearchText = string.Empty;

        if (paginationState.CurrentPageIndex != 0)
        {
            await paginationState.SetCurrentPageIndexAsync(0);
        }
        else if (grid is not null)
        {
            await grid.RefreshDataAsync();
        }
    }

    private async Task HandleSearchKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await ApplySearchAsync();
        }
    }

    private async Task RevokeInviteAsync(Guid inviteId)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to revoke this invite?");
        if (!confirm) return;

        try
        {
            isBusy = true;
            error = null;
            
            await ApiClient.RevokeInviteAsync(inviteId);
            
            if (grid is not null)
            {
                await grid.RefreshDataAsync();
            }
        }
        catch (Exception ex)
        {
            error = "Could not revoke invite: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private static string GetStatusBadge(InviteStatus status) => status switch
    {
        InviteStatus.Pending => "bg-warning text-dark",
        InviteStatus.Accepted => "bg-success",
        InviteStatus.Revoked => "bg-danger",
        InviteStatus.Expired => "bg-dark",
        _ => "bg-secondary"
    };
}