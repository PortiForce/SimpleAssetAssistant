@page "/not-found"

<PageTitle>Not found</PageTitle>

<div class="nf">
    <div class="nf-card">
        <div class="nf-code">404</div>
        <h2>Page not found</h2>
        <p class="nf-text">
            The page you’re looking for doesn’t exist or you don’t have access.
        </p>
        <a class="btn" href="/">Go to Home</a>
    </div>
</div>

<style>
.nf { padding: 18px; display: flex; justify-content: center; }
.nf-card { max-width: 700px; width: 100%; border: 1px solid #e5e7eb; border-radius: 18px; padding: 18px; text-align: center; }
.nf-code { font-size: 56px; font-weight: 800; opacity: .25; }
.nf-text { opacity: .85; }
.btn { display: inline-block; padding: 10px 14px; border-radius: 12px; text-decoration: none; border: 1px solid #e5e7eb; }
</style>