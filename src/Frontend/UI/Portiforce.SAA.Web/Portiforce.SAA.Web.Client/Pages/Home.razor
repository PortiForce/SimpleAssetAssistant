@page "/"
@inject ITenantUrlContext TenantUrlContext

@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Contracts.Contexts
@using Portiforce.SAA.Contracts.Models.Client
@inject IStringLocalizer<Home> L

<PageTitle>@L["PageTitle"]</PageTitle>

@if (TenantUrlContext.IsTenantResolved())
{
    <div class="hero">
        <div class="hero-card">
            <div class="tenant-brand">@TenantBrandName</div>
            <h1>@L["TitleProductName"]</h1>
            <p class="lead">
                @L["SubtitleTenantResolvedLead"]
            </p>

            <AuthorizeView>
                <Authorized>
                    <div class="badge ok">@L["StatusSignedIn"]</div>
                    <p class="mt">@L["InfoNavigateToTenantFeatures"]</p>
                </Authorized>
                <NotAuthorized>
                    <div class="badge warn">@L["StatusInviteOnlyAccess"]</div>
                    <p class="mt">
                        @L["InfoOpenInvitationLinkToJoinTenant"]
                    </p>
                    <a class="btn btn-primary" href="@AuthRoutes.Login">@L["ActionLogIn"]</a>
                </NotAuthorized>
            </AuthorizeView>

            <div class="tiles">
                <div class="tile">
                    <div class="tile-title">@L["TileTitleTenantIsolation"]</div>
                    <div class="tile-text">@L["TileTextTenantIsolation"]</div>
                </div>
                <div class="tile">
                    <div class="tile-title">@L["TileTitleInviteOnlyOnboarding"]</div>
                    <div class="tile-text">@L["TileTextInviteOnlyOnboarding"]</div>
                </div>
                <div class="tile">
                    <div class="tile-title">@L["TileTitleExternalLogin"]</div>
                    <div class="tile-text">@L["TileTextExternalLogin"]</div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="landing">
        <div class="landing-card">
            <h1>@L["TitleProductName"]</h1>
            <p class="lead">
                @L["SubtitleLandingLead"]
            </p>

            <div class="section">
                <h2>@L["SectionTitleWhatIsPortiForce"]</h2>
                <p>
                    @L["SectionTextWhatIsPortiForce"]
                </p>
            </div>

            <div class="section">
                <h2>@L["SectionTitleKeyFeatures"]</h2>
                <ul class="features-list">
                    <li>
                        <strong>@L["FeatureTenantIsolationTitle"]</strong>
                        @L["FeatureTenantIsolationText"]
                    </li>
                    <li>
                        <strong>@L["FeatureActivityTrackingTitle"]</strong>
                        @L["FeatureActivityTrackingText"]
                    </li>
                    <li>
                        <strong>@L["FeatureAssetManagementTitle"]</strong>
                        @L["FeatureAssetManagementText"]
                    </li>
                    <li>
                        <strong>@L["FeatureSecureAuthenticationTitle"]</strong>
                        @L["FeatureSecureAuthenticationText"]
                    </li>
                    <li>
                        <strong>@L["FeatureInviteOnlyAccessTitle"]</strong>
                        @L["FeatureInviteOnlyAccessText"]
                    </li>
                </ul>
            </div>

            <div class="section">
                <h2>@L["SectionTitleHowItWorks"]</h2>
                <p>
                    @L["SectionTextHowItWorks", $"yourcompany.{baseDomain}"]
                </p>
            </div>

            <div class="section info-box">
                <h3>@L["InfoBoxTitleNeedAccess"]</h3>
                <p>
                    @L["InfoBoxTextNeedAccess"]
                </p>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private TenantInfo Tenant { get; set; } = new();

    private string baseDomain => Tenant.BaseDomain;

    private string TenantBrandName => string.IsNullOrWhiteSpace(Tenant.BrandName)
        ? Tenant.Prefix ?? L["TitleProductName"].Value
        : Tenant.BrandName;
}
