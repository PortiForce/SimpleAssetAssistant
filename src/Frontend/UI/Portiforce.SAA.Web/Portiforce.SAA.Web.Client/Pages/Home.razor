@page "/"
@inject ITenantUrlContext TenantUrlContext

@using Microsoft.Extensions.Localization
@using Portiforce.SAA.Contracts.Contexts
@using Portiforce.SAA.Contracts.Models.Client
@inject IStringLocalizer<Home> L

<PageTitle>@L["PageTitle"]</PageTitle>

@if (TenantUrlContext.IsTenantResolved())
{
    <div class="hero">
        <div class="hero-card">
            <div class="tenant-brand">@TenantBrandName</div>
            @if (IsDemoTenant)
            {
                <h1>@L["DemoTenantTitle"]</h1>
                <p class="lead">
                    @L["DemoTenantLead"]
                </p>

                <div class="section info-box">
                    <h2>@L["DemoAccountTitle"]</h2>
                    <p>
                        @L["DemoAccountText"]
                    </p>
                    <div class="actions">
                        <a class="btn btn-primary" href="@DemoAccountRequestHref">@L["ActionRequestDemoAccount"]</a>
                        <a class="btn btn-secondary" href="@AuthRoutes.Login">@L["ActionLogIn"]</a>
                    </div>
                </div>
            }
            else
            {
                <h1>@L["RealTenantTitle"]</h1>
                <p class="lead">
                    @L["RealTenantLead"]
                </p>

                <AuthorizeView>
                    <Authorized>
                        <div class="badge ok">@L["StatusSignedIn"]</div>
                        <p class="mt">@L["InfoNavigateToTenantFeatures"]</p>
                    </Authorized>
                    <NotAuthorized>
                        <div class="badge warn">@L["StatusInviteOnlyAccess"]</div>
                        <p class="mt">
                            @L["InfoOpenInvitationLinkToJoinTenant"]
                        </p>
                        <a class="btn btn-primary" href="@AuthRoutes.Login">@L["ActionLogIn"]</a>
                    </NotAuthorized>
                </AuthorizeView>

                <div class="tiles">
                    <div class="tile">
                        <div class="tile-title">@L["TileTitlePortfolioClarity"]</div>
                        <div class="tile-text">@L["TileTextPortfolioClarity"]</div>
                    </div>
                    <div class="tile">
                        <div class="tile-title">@L["TileTitleTenantIsolation"]</div>
                        <div class="tile-text">@L["TileTextTenantIsolation"]</div>
                    </div>
                    <div class="tile">
                        <div class="tile-title">@L["TileTitleInviteOnlyOnboarding"]</div>
                        <div class="tile-text">@L["TileTextInviteOnlyOnboarding"]</div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="landing">
        <div class="landing-card">
            <h1>@L["TitleProductName"]</h1>
            <p class="lead">
                @L["SubtitleLandingLead"]
            </p>

            <div class="section">
                <h2>@L["SectionTitleTenantBasedPlatform"]</h2>
                <p>
                    @L["SectionTextTenantBasedPlatform"]
                </p>
            </div>

            <div class="section">
                <h2>@L["SectionTitleDemoTenant"]</h2>
                <p>
                    @L["SectionTextDemoTenant", DemoTenantHost]
                </p>
                <a class="btn btn-secondary" href="@DemoTenantUrl">@DemoTenantHost</a>
            </div>

            <div class="section">
                <h2>@L["SectionTitleRequestAccess"]</h2>
                <p>
                    @L["SectionTextRequestAccess"]
                </p>
                <a class="btn btn-primary" href="@ContactMeHref">@L["ActionContactSupport"]</a>
            </div>

            <div class="section info-box">
                <h3>@L["InfoBoxTitleSandboxTenant"]</h3>
                <p>
                    @L["InfoBoxTextSandboxTenant"]
                </p>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private TenantInfo Tenant { get; set; } = new();

    private string DemoTenantHost => L["DemoTenantHost"].Value;

    private string DemoTenantUrl => $"https://{DemoTenantHost}";

    private string ContactMeHref => "/contact-me";

    private string DemoAccountRequestHref => $"{ContactMeHref}?request=demo-account";

    private bool IsDemoTenant => string.Equals(Tenant.Prefix, "demo", StringComparison.OrdinalIgnoreCase);

    private string TenantBrandName => string.IsNullOrWhiteSpace(Tenant.BrandName)
        ? Tenant.Prefix ?? L["TitleProductName"].Value
        : Tenant.BrandName;
}
