@using Portiforce.SAA.Contracts.Models.Client
@using Portiforce.SAA.Web.Client.Services.Interfaces
@inject ITenantApiClient TenantApiClient

<CascadingValue Value="Tenant">
    @ChildContent
</CascadingValue>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private TenantInfo Tenant { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Tenant = await TenantApiClient.GetTenantAsync() ?? new TenantInfo();
    }
}
