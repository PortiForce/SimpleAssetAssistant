{
  "ConnectionStrings": {
    "AssetAssistantSQLDb": "{from-configs}"
  },
  "InviteNotificationWorker": {
    "BatchSize": 25,
    "MaxAttempts": 5,
    "PollInterval": "00:00:30",
    "RunImmediately": true
  },
  "InviteEmailOptions": {
    "FromDisplayName": "{from-configs}",
    "Host": "{from-configs}",
    "Port": "{from-configs}",
    "EnableSsl": "{from-configs}",
    "FromEmail": "{from-configs}",
    "UserName": "{from-configs}",
    "Password": "{from-configs}",
    "SubjectPrefix": "{from-configs}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
