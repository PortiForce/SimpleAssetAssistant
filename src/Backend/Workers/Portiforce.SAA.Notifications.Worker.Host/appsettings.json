{
  "ConnectionStrings": {
    "AssetAssistantSQLDb": "{from-configs}"
  },
  "InviteNotificationWorker": {
    "BatchSize": 25,
    "MaxAttempts": 5,
    "PollInterval": "00:00:30",
    "RunImmediately": true
  },
  "InviteEmailOptions": {
    "FromDisplayName": "Portiforce SAA",
    "Host": "{from-configs}",
    "Port": 587,
    "EnableSsl": true,
    "FromEmail": "{from-configs}",
    "UserName": null,
    "Password": null,
    "SubjectPrefix": null
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
